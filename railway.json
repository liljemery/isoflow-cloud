{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/api/Dockerfile",
    "watchPatterns": ["**"]
  },
  "deploy": {
    "preDeployCommand": "sh -c 'cd /repo/apps/api && npx prisma migrate deploy'",
    "startCommand": "sh -c 'cd /repo/apps/api && exec node dist/index.js'",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE"
  }
}
